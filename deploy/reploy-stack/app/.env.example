# Server configuration
PORT=3000
NODE_ENV=development

# Session management
SESSION_SECRET=your-secure-random-secret-key-here

# First-run bootstrap (required in production; optional in development)
# OWNER_EMAIL=owner@yourdomain.com
# OWNER_PASSWORD=choose-a-strong-password
# OWNER_ORG=Your Company Name

# Claude AI integration
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# (Optional alternative)
# OPENAI_API_KEY=sk-your-openai-key-here

# Stripe (optional unless enabling billing / webhooks)
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email configuration (optional - defaults to log-only mode)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxx
# SMTP_FROM=noreply@yourdomain.com
