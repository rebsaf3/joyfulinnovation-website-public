# NyLi Agent Platform — Environment Variables
# Copy this file to .env and fill in values before running.

# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic API key — used by Claude* agents and NyLiAgent (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used by Codex* agents (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional model overrides
# AGENT_MODEL=claude-haiku-4-5-20251001   # default for Claude* agents
# CODEX_MODEL=gpt-4o-mini                 # default for Codex* agents

# JWT signing secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret

# ─── Owner bootstrap ──────────────────────────────────────────────────────────

# If set, the server will create or update this account with role=owner on every
# startup. Use these in Railway / production so credentials survive redeployment.
# OWNER_EMAIL=you@example.com
# OWNER_PASSWORD=your-secure-password
# OWNER_NAME=Your Name

# ─── Registration ─────────────────────────────────────────────────────────────

# Set to "true" ONLY during initial setup to create your first admin account.
# Set back to "false" (or remove) immediately after to lock down public signup.
ALLOW_REGISTRATION=true

# ─── Deployment (set these in Railway / your hosting provider) ───────────────

# Public URL of this app — used in password-reset email links.
# Example: https://nyli-agent.up.railway.app
APP_URL=http://localhost:5173

# Allowed CORS origin for browser API requests.
# In production set this to your public domain (same as APP_URL).
CLIENT_ORIGIN=http://localhost:5173

# Set to "true" when running behind a reverse proxy / load balancer
# (required on Railway, Render, Heroku, etc. for accurate rate-limit IPs).
TRUST_PROXY=true

# ─── Agent Mesh ───────────────────────────────────────────────────────────────

# Port the local agent dispatch server listens on (default: 3099).
# POST http://127.0.0.1:MESH_PORT/dispatch { agent, task } to send a task.
# MESH_PORT=3099

# Set to "false" to prevent the mesh from auto-starting with the Express server.
# AUTO_START_MESH=true

# Set to "false" to prevent the Vite dashboard from auto-starting in local dev
# when running `npm run dev --prefix server`.
# AUTO_START_DASHBOARD=true

# Heartbeat log interval for each agent process in ms (default: 10000).
# HEARTBEAT_INTERVAL_MS=10000

# Comma-separated list of agents to start (default: all 32).
# AGENT_LIST=ClaudeAgent,CodexAgent,OrchestratorAgent

# ─── Project Supervisor ───────────────────────────────────────────────────────

# Set to "false" to disable the project supervisor process.
# The supervisor monitors projects.json and drives OrchestratorAgent to dispatch
# pending tasks, re-route stalled tasks, and mark projects complete automatically.
# AUTO_START_SUPERVISOR=true

# How often the supervisor checks active projects for pending/stalled tasks (ms).
# Default: 300000 (5 minutes)
# SUPERVISOR_INTERVAL_MS=300000

# How long a task can be in-progress before it's considered stalled (ms).
# Default: 1800000 (30 minutes)
# SUPERVISOR_STALL_MS=1800000

# Max pending tasks surfaced to OrchestratorAgent per supervisor tick.
# Default: 3
# SUPERVISOR_BATCH_SIZE=3

# ─── Optional ─────────────────────────────────────────────────────────────────

# Server port — Railway sets this automatically, leave unset in production.
# PORT=3001

# SQLite database path — set to a Railway Volume mount path for persistence.
# DATABASE_PATH=/data/nyli.db

# ─── Email — SMTP (high-priority transactional) ──────────────────────────────
# Used for: password resets, security alerts, account notifications.
# These emails are sent via your own mail server for maximum reliability.
# Leave unset in dev — links/content will be printed to the server log instead.

# SMTP_HOST=mail.yourdomain.com    # e.g. smtp.office365.com, mail.privateemail.com
# SMTP_PORT=587                    # 587 = STARTTLS (recommended), 465 = SSL
# SMTP_USER=you@yourdomain.com
# SMTP_PASS=your-email-password
# SMTP_FROM=no-reply@yourdomain.com

# ─── Email — SendGrid (bulk / marketing) ─────────────────────────────────────
# Used for: newsletters, announcements, campaign emails to many users at once.
# Configure via Owner Portal → Integrations → sendgrid (not env vars):
#   api_key:          SG.xxx...  (your SendGrid API key)
#   config.from_email verified sender address in your SendGrid account
#   config.from_name  display name shown to recipients (e.g. "NyLi Agent")
#
# Trigger sends via: POST /api/owner/email/send
# Built-in audience targets: all_users | account_owners | trialing | recipients[]
