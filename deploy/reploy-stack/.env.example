# Required core app settings
SESSION_SECRET=replace-with-long-random-secret
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-strong-password
OWNER_ORG=NyLi Assets

# Networking
PORT=3000
MESH_PORT=3099
SWARM_DASHBOARD_AUTH=false

# Persistence (mount this to a persistent volume in Reploy/Railway)
STATE_ROOT=/data
# Optional overrides
# DATABASE_PATH=/data/leo.db
# SWARM_LOGS_DIR=/data/swarm/logs
# SWARM_SERVER_LOGS_DIR=/data/swarm/server-logs

# Optional provider keys (minimal mode activates when both are missing)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional integrations
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Optional swarm controls
# Set this for non-local swarm control API access when SWARM_DASHBOARD_AUTH=false
# SWARM_CONTROL_TOKEN=
# AUTO_START_SUPERVISOR=true
# SUPERVISOR_INTERVAL_MS=300000
