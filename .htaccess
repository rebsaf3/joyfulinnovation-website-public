RewriteEngine On

RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]


# Redirect only index.html to site root
RewriteRule ^index\.html$ / [R=301,L]

# Map blog post clean URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/blog/$1.html -f
RewriteRule ^blog/(.+?)/?$ blog/$1.html [L]
# Internally map clean URLs to existing .html files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Redirect retired FAQ page to Contact
RewriteRule ^faq/?$ /contact [R=301,L]

# Redirect retired InsightPilot support route to Support
RewriteRule ^insightpilot-support/?$ /support [R=301,L]

# Redirect legacy NyLi Assets route to new clean slug
RewriteRule ^product-assetpilot/?$ /nyli-assets [R=301,L]

# Redirect legacy NyLi Insights and NyLi Agent routes to clean slugs
RewriteRule ^product-insightpilot/?$ /nyli-insights [R=301,L]
RewriteRule ^product-flowpilot/?$ /nyli-agent [R=301,L]

# Redirect legacy blog URLs to /blog/
RewriteRule ^(insight-[^/]+)/?$ /blog/$1 [R=301,L]



