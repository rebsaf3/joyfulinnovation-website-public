# Standard Python/Node/General ignores
__pycache__/
node_modules/
.env
.DS_Store
*.pyc
*.pyo
*.log
.idea/
.vscode/
dist/
build/

# Explicit credential files (also caught by the global .env rule above)
deploy/reploy-stack/app/.env

# Runtime/local state artifacts
*.db
*.db-shm
*.db-wal
deploy/reploy-stack/app/data/*.db
deploy/reploy-stack/app/data/*.db-shm
deploy/reploy-stack/app/data/*.db-wal
